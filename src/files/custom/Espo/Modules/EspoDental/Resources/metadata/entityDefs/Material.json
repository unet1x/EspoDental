{
    "fields": {
        "name": {"type": "varchar", "required": true, "maxLength": 255},
        "code": {"type": "varchar", "maxLength": 50, "trim": true},
        "sku": {"type": "varchar", "maxLength": 64},
        "category": {"type": "link", "required": true},
        "unit": {
            "type": "enum",
            "options": ["pcs", "ml", "g", "kg", "l", "box", "pack", "syringe", "tube", "cartridge"],
            "default": "pcs",
            "required": true
        },
        "manufacturer": {"type": "varchar", "maxLength": 128},
        "vendor": {"type": "varchar", "maxLength": 128},
        "price": {"type": "currency", "default": "0.00"},
        "color": {"type": "varchar", "maxLength": 9, "view": "views/fields/colorpicker"},
        "minStock": {"type": "float", "default": 0, "min": 0, "tooltip": true},
        "criticalStock": {"type": "float", "default": 0, "min": 0, "tooltip": true},
        "maxStock": {"type": "float", "default": 0, "min": 0},
        "currentStock": {"type": "float", "readOnly": true, "default": 0},
        "stockLevel": {
            "type": "enum",
            "options": ["", "ok", "low", "critical", "out"],
            "readOnly": true,
            "default": "ok",
            "style": {"": "default", "ok": "success", "low": "warning", "critical": "danger", "out": "danger"}
        },
        "expiryControl": {"type": "bool", "default": false},
        "isActive": {"type": "bool", "default": true},
        "description": {"type": "text"},
        "createdAt": {"type": "datetime", "readOnly": true},
        "modifiedAt": {"type": "datetime", "readOnly": true},
        "createdBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "modifiedBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "assignedUser": {"type": "link", "view": "views/fields/assigned-user"},
        "teams": {"type": "linkMultiple", "view": "views/fields/teams"}
    },
    "links": {
        "category": {"type": "belongsTo", "entity": "MaterialCategory", "foreign": "materials"},
        "movements": {"type": "hasMany", "entity": "StockMovement", "foreign": "material"},
        "serviceMaterials": {"type": "hasMany", "entity": "ServiceMaterial", "foreign": "material"},
        "visitMaterialLines": {"type": "hasMany", "entity": "VisitMaterialLine", "foreign": "material"},
        "alerts": {"type": "hasMany", "entity": "LowStockAlert", "foreign": "material"},
        "createdBy": {"type": "belongsTo", "entity": "User"},
        "modifiedBy": {"type": "belongsTo", "entity": "User"},
        "assignedUser": {"type": "belongsTo", "entity": "User"},
        "teams": {"type": "hasMany", "entity": "Team", "relationName": "entityTeam", "layoutRelationshipsDisabled": true}
    },
    "collection": {"orderBy": "name", "order": "asc"},
    "indexes": {
        "code": {"columns": ["code"]},
        "category_active": {"columns": ["categoryId", "isActive"]},
        "stockLevel": {"columns": ["stockLevel"]}
    }
}
