{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "maxLength": 100,
            "trim": true
        },
        "code": {
            "type": "varchar",
            "maxLength": 40,
            "trim": true
        },
        "clinic": {
            "type": "link",
            "required": true
        },
        "color": {
            "type": "varchar",
            "maxLength": 9,
            "view": "views/fields/colorpicker"
        },
        "equipment": {
            "type": "text"
        },
        "order": {
            "type": "int",
            "default": 0
        },
        "isActive": {
            "type": "bool",
            "default": true
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        }
    },
    "links": {
        "clinic": {
            "type": "belongsTo",
            "entity": "Clinic",
            "foreign": "cabinets"
        },
        "appointments": {
            "type": "hasMany",
            "entity": "Appointment",
            "foreign": "cabinet"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        }
    },
    "collection": {
        "orderBy": "order",
        "order": "asc"
    },
    "indexes": {
        "clinic_name": {
            "columns": ["clinicId", "name"]
        },
        "clinic_code": {
            "columns": ["clinicId", "code"],
            "unique": true
        }
    }
}
