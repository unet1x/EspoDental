{
    "fields": {
        "name": {"type": "varchar", "required": true, "maxLength": 255},
        "clinic": {"type": "link"},
        "secretKind": {
            "type": "enum",
            "options": ["provider_token", "smtp_password", "api_key"],
            "required": true
        },
        "secretValue": {"type": "password"},
        "valuePresent": {"type": "bool", "readOnly": true, "default": false},
        "updatedAt": {"type": "datetime", "readOnly": true},
        "updatedBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "createdAt": {"type": "datetime", "readOnly": true},
        "modifiedAt": {"type": "datetime", "readOnly": true},
        "createdBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "modifiedBy": {"type": "link", "readOnly": true, "view": "views/fields/user"}
    },
    "links": {
        "clinic": {"type": "belongsTo", "entity": "Clinic"},
        "updatedBy": {"type": "belongsTo", "entity": "User"},
        "createdBy": {"type": "belongsTo", "entity": "User"},
        "modifiedBy": {"type": "belongsTo", "entity": "User"}
    },
    "collection": {"orderBy": "name", "order": "asc"},
    "indexes": {
        "clinic_name": {"columns": ["clinicId", "name"], "unique": true}
    }
}
