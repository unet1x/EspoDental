{
    "fields": {
        "name": {"type": "varchar", "required": true, "maxLength": 255},
        "invoice": {"type": "link", "required": true},
        "service": {"type": "link"},
        "doctor": {"type": "link", "view": "views/fields/user"},
        "teethNumbers": {"type": "varchar", "maxLength": 64},
        "quantity": {"type": "int", "default": 1, "min": 1, "required": true},
        "unitPrice": {"type": "currency", "default": "0.00", "required": true},
        "discount": {"type": "float", "default": 0, "min": 0, "max": 100},
        "amount": {"type": "currency", "readOnly": true, "default": "0.00"},
        "vatRate": {"type": "float", "default": 0, "min": 0, "max": 100},
        "vatAmount": {"type": "currency", "readOnly": true, "default": "0.00"},
        "sourceVisitServiceLine": {"type": "link"},
        "notes": {"type": "text"},
        "createdAt": {"type": "datetime", "readOnly": true},
        "modifiedAt": {"type": "datetime", "readOnly": true},
        "createdBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "modifiedBy": {"type": "link", "readOnly": true, "view": "views/fields/user"}
    },
    "links": {
        "invoice": {"type": "belongsTo", "entity": "Invoice", "foreign": "lines"},
        "service": {"type": "belongsTo", "entity": "Service"},
        "doctor": {"type": "belongsTo", "entity": "User"},
        "sourceVisitServiceLine": {"type": "belongsTo", "entity": "VisitServiceLine"},
        "createdBy": {"type": "belongsTo", "entity": "User"},
        "modifiedBy": {"type": "belongsTo", "entity": "User"}
    },
    "collection": {"orderBy": "createdAt", "order": "asc"},
    "indexes": {
        "invoice": {"columns": ["invoiceId", "deleted"]}
    }
}
