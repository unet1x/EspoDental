{
    "controller": "controllers/record",
    "createDisabled": true,
    "color": "#D62728",
    "iconClass": "fas fa-stethoscope",
    "kanbanViewMode": false,
    "recordViews": {
        "detail": "espo-dental:views/visit/record/detail"
    },
    "defaultSidePanelFieldLists": {
        "detail": ["createdAt", "modifiedAt"],
        "detailSmall": ["createdAt", "modifiedAt"]
    },
    "menu": {
        "detail": {
            "buttons": [
                {
                    "name": "finishVisit",
                    "label": "Finish Visit",
                    "style": "primary",
                    "acl": "edit",
                    "handler": "espo-dental:handlers/visit/finish-visit",
                    "actionFunction": "actionFinishVisit",
                    "checkVisibilityFunction": "isFinishVisitAvailable",
                    "hidden": false
                },
                {
                    "name": "bookNextAppointment",
                    "label": "Book Next Appointment",
                    "style": "default",
                    "acl": "edit",
                    "handler": "espo-dental:handlers/visit/book-next-appointment",
                    "actionFunction": "actionBookNextAppointment",
                    "checkVisibilityFunction": "isBookNextAppointmentAvailable"
                }
            ]
        }
    }
}
