{
    "fields": {
        "name": {"type": "varchar", "readOnly": true, "maxLength": 255},
        "clinic": {"type": "link", "required": true},
        "documentType": {
            "type": "enum",
            "options": ["invoice", "act", "receipt"],
            "required": true
        },
        "prefix": {"type": "varchar", "required": true, "maxLength": 16},
        "nextNumber": {"type": "int", "required": true, "default": 1, "min": 1},
        "digits": {"type": "int", "required": true, "default": 6, "min": 1, "max": 12},
        "year": {"type": "int", "min": 2000, "max": 2100},
        "isActive": {"type": "bool", "default": true},
        "createdAt": {"type": "datetime", "readOnly": true},
        "modifiedAt": {"type": "datetime", "readOnly": true},
        "createdBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "modifiedBy": {"type": "link", "readOnly": true, "view": "views/fields/user"}
    },
    "links": {
        "clinic": {"type": "belongsTo", "entity": "Clinic"},
        "createdBy": {"type": "belongsTo", "entity": "User"},
        "modifiedBy": {"type": "belongsTo", "entity": "User"}
    },
    "collection": {"orderBy": "documentType", "order": "asc"},
    "indexes": {
        "clinic_document": {"columns": ["clinicId", "documentType", "year"], "unique": true}
    }
}
