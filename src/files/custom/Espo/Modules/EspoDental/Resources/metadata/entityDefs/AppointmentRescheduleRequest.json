{
    "fields": {
        "name": {"type": "varchar", "readOnly": true, "maxLength": 255},
        "appointment": {"type": "link", "required": true},
        "patient": {"type": "link", "required": true},
        "requestedBy": {
            "type": "enum",
            "options": ["patient", "admin", "ai_agent"],
            "default": "patient"
        },
        "source": {
            "type": "enum",
            "options": ["patient_portal", "reminder_link", "admin_ui", "ai_agent"],
            "default": "patient_portal"
        },
        "requestedStartAt": {"type": "datetime", "required": true},
        "requestedEndAt": {"type": "datetime", "required": true},
        "requestedDoctor": {"type": "link", "view": "views/fields/user"},
        "requestedCabinet": {"type": "link"},
        "requestedClinic": {"type": "link"},
        "previousAppointmentStatus": {"type": "varchar", "readOnly": true, "maxLength": 64},
        "status": {
            "type": "enum",
            "options": [
                "pending_clinic_confirmation",
                "approved",
                "rejected",
                "slot_unavailable",
                "cancelled_by_patient",
                "escalated_to_admin"
            ],
            "default": "pending_clinic_confirmation",
            "audited": true,
            "style": {
                "pending_clinic_confirmation": "warning",
                "approved": "success",
                "rejected": "danger",
                "slot_unavailable": "danger",
                "cancelled_by_patient": "muted",
                "escalated_to_admin": "info"
            }
        },
        "patientComment": {"type": "text"},
        "internalComment": {"type": "text"},
        "confirmedAt": {"type": "datetime", "readOnly": true},
        "confirmedBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "rejectedAt": {"type": "datetime", "readOnly": true},
        "rejectionReason": {"type": "text"},
        "createdAt": {"type": "datetime", "readOnly": true},
        "modifiedAt": {"type": "datetime", "readOnly": true},
        "createdBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "modifiedBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "assignedUser": {"type": "link", "view": "views/fields/assigned-user"},
        "teams": {"type": "linkMultiple", "view": "views/fields/teams"}
    },
    "links": {
        "appointment": {"type": "belongsTo", "entity": "Appointment", "foreign": "rescheduleRequests"},
        "patient": {"type": "belongsTo", "entity": "Patient", "foreign": "rescheduleRequests"},
        "requestedDoctor": {"type": "belongsTo", "entity": "User"},
        "requestedCabinet": {"type": "belongsTo", "entity": "Cabinet"},
        "requestedClinic": {"type": "belongsTo", "entity": "Clinic"},
        "confirmedBy": {"type": "belongsTo", "entity": "User"},
        "portalEvents": {
            "type": "hasMany",
            "entity": "PatientPortalEvent",
            "foreign": "rescheduleRequest"
        },
        "createdBy": {"type": "belongsTo", "entity": "User"},
        "modifiedBy": {"type": "belongsTo", "entity": "User"},
        "assignedUser": {"type": "belongsTo", "entity": "User"},
        "teams": {"type": "hasMany", "entity": "Team", "relationName": "entityTeam", "layoutRelationshipsDisabled": true}
    },
    "collection": {"orderBy": "createdAt", "order": "desc"},
    "indexes": {
        "appointment_status": {"columns": ["appointmentId", "status"]},
        "patient_status": {"columns": ["patientId", "status"]},
        "requestedStartAt": {"columns": ["requestedStartAt"]}
    }
}
