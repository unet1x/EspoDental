{
    "controller": "controllers/record",
    "createDisabled": true,
    "removeDisabled": true,
    "boolFilterList": ["onlyMy", "vip", "restrictions"],
    "color": "#17BECF",
    "iconClass": "fas fa-user-injured",
    "kanbanViewMode": false,
    "recordViews": {
        "detail": "espo-dental:views/patient/record/detail"
    },
    "defaultSidePanelFieldLists": {
        "detail": ["createdAt", "createdBy"],
        "detailSmall": ["createdAt", "createdBy"]
    },
    "relationshipPanels": {
        "appointments": {
            "create": false,
            "select": false,
            "createDisabled": true,
            "selectDisabled": true
        },
        "photos": {
            "create": false,
            "select": false,
            "createDisabled": true,
            "selectDisabled": true
        },
        "healthQuestionnaires": {
            "create": false,
            "select": false,
            "createDisabled": true,
            "selectDisabled": true
        }
    },
    "menu": {
        "detail": {
            "buttons": [
                {
                    "name": "bookAppointment",
                    "label": "Book Appointment",
                    "style": "primary",
                    "acl": "edit",
                    "handler": "espo-dental:handlers/patient/book-appointment",
                    "actionFunction": "actionBookAppointment",
                    "checkVisibilityFunction": "isBookAppointmentAvailable"
                },
                {
                    "name": "issueQuestionnaire",
                    "label": "Health Questionnaire",
                    "style": "warning",
                    "acl": "edit",
                    "handler": "espo-dental:handlers/patient/issue-questionnaire",
                    "actionFunction": "actionIssueQuestionnaire",
                    "checkVisibilityFunction": "isIssueQuestionnaireAvailable"
                }
            ]
        }
    },
    "dynamicLogic": {
        "fields": {
            "parentLastName": {
                "visible": {
                    "conditionGroup": [
                        {"type": "isTrue", "attribute": "isChild"}
                    ]
                }
            },
            "parentPatient": {
                "visible": {
                    "conditionGroup": [
                        {"type": "isTrue", "attribute": "isChild"}
                    ]
                }
            },
            "parentFirstName": {
                "visible": {
                    "conditionGroup": [
                        {"type": "isTrue", "attribute": "isChild"}
                    ]
                }
            },
            "parentMiddleName": {
                "visible": {
                    "conditionGroup": [
                        {"type": "isTrue", "attribute": "isChild"}
                    ]
                }
            },
            "parentPhone": {
                "visible": {
                    "conditionGroup": [
                        {"type": "isTrue", "attribute": "isChild"}
                    ]
                }
            },
            "parentRelation": {
                "visible": {
                    "conditionGroup": [
                        {"type": "isTrue", "attribute": "isChild"}
                    ]
                }
            }
        }
    }
}
