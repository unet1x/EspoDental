{
    "fields": {
        "name": {"type": "varchar", "readOnly": true, "maxLength": 255},
        "patient": {"type": "link", "required": true},
        "visit": {"type": "link"},
        "doctor": {"type": "link", "view": "views/fields/user"},
        "dentitionType": {
            "type": "enum",
            "options": ["adult", "child", "mixed"],
            "default": "adult",
            "required": true
        },
        "teeth": {"type": "jsonObject", "default": "{}"},
        "recordedAt": {"type": "datetime", "required": true},
        "notes": {"type": "text"},
        "createdAt": {"type": "datetime", "readOnly": true},
        "modifiedAt": {"type": "datetime", "readOnly": true},
        "createdBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "modifiedBy": {"type": "link", "readOnly": true, "view": "views/fields/user"}
    },
    "links": {
        "patient": {"type": "belongsTo", "entity": "Patient", "foreign": "toothChartSnapshots"},
        "visit": {"type": "belongsTo", "entity": "Visit", "foreign": "toothChartSnapshots"},
        "doctor": {"type": "belongsTo", "entity": "User"},
        "createdBy": {"type": "belongsTo", "entity": "User"},
        "modifiedBy": {"type": "belongsTo", "entity": "User"}
    },
    "collection": {"orderBy": "recordedAt", "order": "desc"},
    "indexes": {
        "patient_recorded": {"columns": ["patientId", "recordedAt"]},
        "visit": {"columns": ["visitId"]}
    }
}
