{
    "fields": {
        "name": {
            "type": "varchar",
            "readOnly": true,
            "maxLength": 255
        },
        "doctor": {
            "type": "link",
            "required": true,
            "view": "views/fields/user"
        },
        "assistant": {
            "type": "link",
            "view": "views/fields/user"
        },
        "clinic": {
            "type": "link",
            "required": true
        },
        "cabinet": {
            "type": "link"
        },
        "weekday": {
            "type": "enum",
            "required": true,
            "options": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"],
            "default": "monday"
        },
        "timeStart": {
            "type": "varchar",
            "required": true,
            "maxLength": 5,
            "default": "08:00"
        },
        "timeEnd": {
            "type": "varchar",
            "required": true,
            "maxLength": 5,
            "default": "14:00"
        },
        "dateStart": {
            "type": "date",
            "required": true
        },
        "dateEnd": {
            "type": "date",
            "required": true,
            "after": "dateStart"
        },
        "type": {
            "type": "enum",
            "required": true,
            "options": ["regular", "additional", "closed"],
            "default": "regular",
            "style": {
                "regular": "primary",
                "additional": "success",
                "closed": "danger"
            }
        },
        "status": {
            "type": "enum",
            "required": true,
            "options": ["active", "paused"],
            "default": "active",
            "style": {
                "active": "success",
                "paused": "muted"
            }
        },
        "lastGeneratedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "description": {
            "type": "text"
        },
        "createdAt": {"type": "datetime", "readOnly": true},
        "modifiedAt": {"type": "datetime", "readOnly": true},
        "createdBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "modifiedBy": {"type": "link", "readOnly": true, "view": "views/fields/user"}
    },
    "links": {
        "doctor": {"type": "belongsTo", "entity": "User"},
        "assistant": {"type": "belongsTo", "entity": "User"},
        "clinic": {"type": "belongsTo", "entity": "Clinic"},
        "cabinet": {"type": "belongsTo", "entity": "Cabinet"},
        "shifts": {"type": "hasMany", "entity": "DoctorShift", "foreign": "shiftTemplate"},
        "createdBy": {"type": "belongsTo", "entity": "User"},
        "modifiedBy": {"type": "belongsTo", "entity": "User"}
    },
    "collection": {
        "orderBy": "dateStart",
        "order": "desc"
    },
    "indexes": {
        "doctor_weekday": {"columns": ["doctorId", "weekday", "status"]},
        "clinic_status": {"columns": ["clinicId", "status"]}
    }
}
