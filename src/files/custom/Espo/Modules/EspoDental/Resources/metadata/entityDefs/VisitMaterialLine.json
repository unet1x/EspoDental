{
    "fields": {
        "name": {"type": "varchar", "readOnly": true, "maxLength": 255},
        "visit": {"type": "link", "required": true},
        "visitServiceLine": {"type": "link", "required": false},
        "service": {"type": "link", "readOnly": true},
        "material": {"type": "link", "required": true},
        "plannedQuantity": {"type": "float", "readOnly": true, "default": 0, "min": 0},
        "quantity": {"type": "float", "required": true, "default": 0, "min": 0},
        "unit": {"type": "varchar", "maxLength": 16, "readOnly": true},
        "unitPrice": {"type": "currency", "default": "0.00", "readOnly": true},
        "totalCost": {"type": "currency", "readOnly": true, "default": "0.00"},
        "isAutoCreated": {"type": "bool", "default": false, "readOnly": true},
        "notes": {"type": "text"},
        "createdAt": {"type": "datetime", "readOnly": true},
        "modifiedAt": {"type": "datetime", "readOnly": true},
        "createdBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "modifiedBy": {"type": "link", "readOnly": true, "view": "views/fields/user"}
    },
    "links": {
        "visit": {"type": "belongsTo", "entity": "Visit", "foreign": "materialLines"},
        "visitServiceLine": {
            "type": "belongsTo",
            "entity": "VisitServiceLine",
            "foreign": "materialLines"
        },
        "service": {"type": "belongsTo", "entity": "Service"},
        "material": {"type": "belongsTo", "entity": "Material"},
        "createdBy": {"type": "belongsTo", "entity": "User"},
        "modifiedBy": {"type": "belongsTo", "entity": "User"}
    },
    "collection": {"orderBy": "createdAt", "order": "asc"},
    "indexes": {
        "visit": {"columns": ["visitId", "deleted"]},
        "visit_service_line_material": {
            "columns": ["visitServiceLineId", "materialId"],
            "unique": true
        },
        "material": {"columns": ["materialId"]}
    }
}
