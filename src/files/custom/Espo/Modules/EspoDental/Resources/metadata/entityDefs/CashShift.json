{
    "fields": {
        "name": {"type": "varchar", "readOnly": true, "maxLength": 255},
        "clinic": {"type": "link", "required": true},
        "cashier": {"type": "link", "required": true, "view": "views/fields/user"},
        "status": {
            "type": "enum",
            "options": ["open", "closed"],
            "default": "open",
            "style": {"open": "warning", "closed": "success"}
        },
        "openedAt": {"type": "datetime", "required": true},
        "closedAt": {"type": "datetime"},
        "periodFrom": {"type": "datetime"},
        "periodTo": {"type": "datetime"},
        "cashTotal": {"type": "currency", "readOnly": true, "default": "0.00"},
        "cardTotal": {"type": "currency", "readOnly": true, "default": "0.00"},
        "cryptoTotal": {"type": "currency", "readOnly": true, "default": "0.00"},
        "advanceTotal": {"type": "currency", "readOnly": true, "default": "0.00"},
        "invoiceTotal": {"type": "currency", "readOnly": true, "default": "0.00"},
        "notes": {"type": "text"},
        "createdAt": {"type": "datetime", "readOnly": true},
        "modifiedAt": {"type": "datetime", "readOnly": true},
        "createdBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "modifiedBy": {"type": "link", "readOnly": true, "view": "views/fields/user"}
    },
    "links": {
        "clinic": {"type": "belongsTo", "entity": "Clinic"},
        "cashier": {"type": "belongsTo", "entity": "User"},
        "payments": {"type": "hasMany", "entity": "Payment", "foreign": "cashShift"},
        "createdBy": {"type": "belongsTo", "entity": "User"},
        "modifiedBy": {"type": "belongsTo", "entity": "User"}
    },
    "collection": {"orderBy": "openedAt", "order": "desc"},
    "indexes": {
        "clinic_status": {"columns": ["clinicId", "status"]},
        "cashier_opened": {"columns": ["cashierId", "openedAt"]}
    }
}
