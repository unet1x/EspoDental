{
    "controller": "controllers/record",
    "createDisabled": true,
    "color": "#BCBD22",
    "iconClass": "fas fa-file-invoice-dollar",
    "kanbanViewMode": true,
    "boolFilterList": ["onlyOpen", "onlyOverdue"],
    "menu": {
        "detail": {
            "buttons": [
                {
                    "name": "issue",
                    "label": "Issue",
                    "style": "primary",
                    "acl": "edit",
                    "handler": "espo-dental:handlers/invoice/issue",
                    "actionFunction": "actionIssue"
                },
                {
                    "name": "acceptPayment",
                    "label": "Accept Payment",
                    "style": "primary",
                    "acl": "edit",
                    "handler": "espo-dental:handlers/invoice/accept-payment",
                    "actionFunction": "actionAcceptPayment"
                },
                {
                    "name": "storno",
                    "label": "Storno",
                    "style": "danger",
                    "acl": "edit",
                    "handler": "espo-dental:handlers/invoice/storno",
                    "actionFunction": "actionStorno"
                },
                {
                    "name": "printPdf",
                    "label": "Print PDF",
                    "style": "default",
                    "acl": "read",
                    "handler": "espo-dental:handlers/invoice/print-pdf",
                    "actionFunction": "actionPrintPdf"
                },
                {
                    "name": "bookNextAppointment",
                    "label": "Book Next Appointment",
                    "style": "default",
                    "acl": "edit",
                    "handler": "espo-dental:handlers/invoice/book-next-appointment",
                    "actionFunction": "actionBookNextAppointment",
                    "checkVisibilityFunction": "isBookNextAppointmentAvailable"
                }
            ]
        }
    }
}
