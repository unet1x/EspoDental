{
    "fields": {
        "number": {"type": "varchar", "maxLength": 32, "readOnly": true, "trim": true},
        "name": {"type": "varchar", "readOnly": true, "maxLength": 255},
        "patient": {"type": "link", "required": true},
        "clinic": {"type": "link", "required": true},
        "invoice": {"type": "link"},
        "method": {
            "type": "varchar",
            "maxLength": 64,
            "default": "cash",
            "required": true,
            "tooltip": true
        },
        "amount": {"type": "currency", "required": true, "default": "0.00"},
        "currency": {"type": "varchar", "maxLength": 8, "default": "RUB"},
        "status": {
            "type": "enum",
            "options": ["pending", "completed", "cancelled", "refunded"],
            "default": "completed",
            "audited": true,
            "style": {
                "pending": "warning",
                "completed": "success",
                "cancelled": "muted",
                "refunded": "danger"
            }
        },
        "direction": {
            "type": "enum",
            "options": ["in", "out"],
            "default": "in",
            "required": true,
            "tooltip": true
        },
        "paidAt": {"type": "datetime", "required": true},
        "receivedBy": {"type": "link", "view": "views/fields/user"},
        "refundOf": {"type": "link"},
        "isReversed": {"type": "bool", "readOnly": true, "default": false},
        "reversedAt": {"type": "datetime", "readOnly": true},
        "reversedBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "reverseReason": {"type": "text", "readOnly": true},
        "externalReference": {"type": "varchar", "maxLength": 128},
        "cryptoAsset": {"type": "varchar", "maxLength": 16},
        "cryptoAmount": {"type": "float", "min": 0},
        "cashShift": {"type": "link"},
        "notes": {"type": "text"},
        "createdAt": {"type": "datetime", "readOnly": true},
        "modifiedAt": {"type": "datetime", "readOnly": true},
        "createdBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "modifiedBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "assignedUser": {"type": "link", "view": "views/fields/assigned-user"},
        "teams": {"type": "linkMultiple", "view": "views/fields/teams"}
    },
    "links": {
        "patient": {"type": "belongsTo", "entity": "Patient", "foreign": "payments"},
        "clinic": {"type": "belongsTo", "entity": "Clinic"},
        "invoice": {"type": "belongsTo", "entity": "Invoice", "foreign": "payments"},
        "receivedBy": {"type": "belongsTo", "entity": "User"},
        "refundOf": {"type": "belongsTo", "entity": "Payment"},
        "reversedBy": {"type": "belongsTo", "entity": "User"},
        "cashShift": {"type": "belongsTo", "entity": "CashShift", "foreign": "payments"},
        "createdBy": {"type": "belongsTo", "entity": "User"},
        "modifiedBy": {"type": "belongsTo", "entity": "User"},
        "assignedUser": {"type": "belongsTo", "entity": "User"},
        "teams": {"type": "hasMany", "entity": "Team", "relationName": "entityTeam", "layoutRelationshipsDisabled": true}
    },
    "collection": {"orderBy": "paidAt", "order": "desc"},
    "indexes": {
        "number": {"columns": ["number"], "unique": true},
        "patient_paid": {"columns": ["patientId", "paidAt"]},
        "invoice": {"columns": ["invoiceId"]},
        "status": {"columns": ["status"]}
    }
}
