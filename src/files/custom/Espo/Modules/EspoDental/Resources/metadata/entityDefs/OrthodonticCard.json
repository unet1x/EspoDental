{
    "fields": {
        "name": {"type": "varchar", "readOnly": true, "maxLength": 255},
        "cardNumber": {"type": "varchar", "readOnly": true, "maxLength": 32},
        "patient": {"type": "link", "required": true},
        "clinic": {"type": "link"},
        "doctor": {"type": "link", "view": "views/fields/user"},
        "dateOpen": {"type": "date", "required": true},
        "dateClose": {"type": "date"},
        "status": {
            "type": "enum",
            "options": ["open", "in_treatment", "retention", "completed", "cancelled"],
            "default": "open",
            "audited": true,
            "style": {
                "open": "info",
                "in_treatment": "primary",
                "retention": "warning",
                "completed": "success",
                "cancelled": "muted"
            }
        },
        "chiefComplaint": {"type": "text"},
        "anamnesis": {"type": "text"},
        "diagnosis": {"type": "text"},
        "malocclusionClass": {
            "type": "enum",
            "options": ["", "I", "II_div1", "II_div2", "III", "crossbite", "openbite", "deepbite", "other"]
        },
        "skeletalClass": {"type": "enum", "options": ["", "I", "II", "III", "mixed"]},
        "growthStage": {
            "type": "enum",
            "options": ["", "pre_pubertal", "pubertal", "post_pubertal", "adult"]
        },
        "apparatusType": {
            "type": "enum",
            "options": [
                "", "brackets_metal", "brackets_ceramic", "brackets_lingual",
                "aligners", "plates", "headgear", "twin_block", "retainer", "other"
            ]
        },
        "estimatedDurationMonths": {"type": "int", "min": 1, "max": 60},
        "treatmentPlan": {"type": "text"},
        "extractionPlan": {"type": "text"},
        "notes": {"type": "text"},
        "createdAt": {"type": "datetime", "readOnly": true},
        "modifiedAt": {"type": "datetime", "readOnly": true},
        "createdBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "modifiedBy": {"type": "link", "readOnly": true, "view": "views/fields/user"}
    },
    "links": {
        "patient": {"type": "belongsTo", "entity": "Patient", "foreign": "orthodonticCards"},
        "clinic": {"type": "belongsTo", "entity": "Clinic"},
        "doctor": {"type": "belongsTo", "entity": "User"},
        "stages": {"type": "hasMany", "entity": "TreatmentStage", "foreign": "card"},
        "toothMovementPlans": {"type": "hasMany", "entity": "ToothMovementPlan", "foreign": "card"},
        "photos": {"type": "hasMany", "entity": "OrthoPhoto", "foreign": "card"},
        "cephMeasurements": {
            "type": "hasMany",
            "entity": "CephalometricMeasurement",
            "foreign": "card"
        },
        "createdBy": {"type": "belongsTo", "entity": "User"},
        "modifiedBy": {"type": "belongsTo", "entity": "User"}
    },
    "collection": {"orderBy": "dateOpen", "order": "desc"},
    "indexes": {
        "patient": {"columns": ["patientId"]},
        "status": {"columns": ["status", "deleted"]},
        "cardNumber": {"columns": ["cardNumber"], "unique": true}
    }
}
