{
    "view": "espo-dental:views/dashlets/resource-calendar-feedback",
    "aclScope": "Appointment",
    "options": {
        "fields": {
            "title": {"type": "varchar", "default": "Resource Calendar"},
            "defaultView": {
                "type": "enum",
                "default": "day",
                "options": ["day", "week"]
            },
            "clinic": {"type": "link", "view": "views/fields/link", "entity": "Clinic"},
            "cabinet": {"type": "link", "view": "views/fields/link", "entity": "Cabinet"},
            "rowMinutes": {
                "type": "enumInt",
                "default": 30,
                "options": [10, 15, 30, 60]
            },
            "startHour": {"type": "int", "default": 8, "min": 0, "max": 23},
            "endHour": {"type": "int", "default": 21, "min": 1, "max": 24},
            "displayRecords": {"type": "int", "default": 12, "min": 1, "max": 30},
            "autorefreshInterval": {
                "type": "enumFloat",
                "default": 0,
                "options": [0, 1, 5, 10]
            }
        }
    }
}
