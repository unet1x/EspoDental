{
    "view": "espo-dental:views/dashlets/resource-calendar",
    "aclScope": "Appointment",
    "options": {
        "fields": {
            "title": {"type": "varchar", "default": "Resource Calendar"},
            "clinic": {"type": "link", "view": "views/fields/link", "entity": "Clinic"},
            "rowMinutes": {
                "type": "enumInt",
                "default": 30,
                "options": [10, 15, 30, 60]
            },
            "startHour": {"type": "int", "default": 8, "min": 0, "max": 23},
            "endHour": {"type": "int", "default": 21, "min": 1, "max": 24},
            "autorefreshInterval": {
                "type": "enumFloat",
                "default": 0,
                "options": [0, 1, 5, 10]
            }
        }
    }
}
