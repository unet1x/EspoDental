{
    "fields": {
        "name": {
            "type": "varchar",
            "readOnly": true,
            "maxLength": 255
        },
        "doctor": {
            "type": "link",
            "view": "views/fields/user"
        },
        "assistant": {
            "type": "link",
            "view": "views/fields/user"
        },
        "clinic": {
            "type": "link",
            "required": true
        },
        "cabinet": {
            "type": "link"
        },
        "dateStart": {
            "type": "datetime",
            "required": true
        },
        "dateEnd": {
            "type": "datetime",
            "required": true,
            "after": "dateStart"
        },
        "type": {
            "type": "enum",
            "required": true,
            "options": ["regular", "additional", "closed"],
            "default": "regular",
            "style": {
                "regular": "primary",
                "additional": "success",
                "closed": "danger"
            }
        },
        "status": {
            "type": "enum",
            "required": true,
            "options": ["active", "cancelled"],
            "default": "active",
            "style": {
                "active": "success",
                "cancelled": "muted"
            }
        },
        "shiftTemplate": {
            "type": "link",
            "readOnly": true
        },
        "description": {
            "type": "text"
        },
        "createdAt": {"type": "datetime", "readOnly": true},
        "modifiedAt": {"type": "datetime", "readOnly": true},
        "createdBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "modifiedBy": {"type": "link", "readOnly": true, "view": "views/fields/user"}
    },
    "links": {
        "doctor": {"type": "belongsTo", "entity": "User"},
        "assistant": {"type": "belongsTo", "entity": "User"},
        "clinic": {"type": "belongsTo", "entity": "Clinic"},
        "cabinet": {"type": "belongsTo", "entity": "Cabinet"},
        "shiftTemplate": {"type": "belongsTo", "entity": "DoctorShiftTemplate", "foreign": "shifts"},
        "createdBy": {"type": "belongsTo", "entity": "User"},
        "modifiedBy": {"type": "belongsTo", "entity": "User"}
    },
    "collection": {
        "orderBy": "dateStart",
        "order": "desc"
    },
    "indexes": {
        "doctor_date": {"columns": ["doctorId", "dateStart", "dateEnd"]},
        "clinic_date": {"columns": ["clinicId", "dateStart"]},
        "cabinet_date": {"columns": ["cabinetId", "dateStart"]},
        "shift_template": {"columns": ["shiftTemplateId"]},
        "status": {"columns": ["status", "deleted"]}
    }
}
