{
    "fields": {
        "name": {
            "type": "personName",
            "isPersonalData": true,
            "view": "views/fields/person-name"
        },
        "lastName": {
            "type": "varchar",
            "required": true,
            "maxLength": 100,
            "trim": true,
            "isPersonalData": true
        },
        "firstName": {
            "type": "varchar",
            "required": true,
            "maxLength": 100,
            "trim": true,
            "isPersonalData": true
        },
        "middleName": {
            "type": "varchar",
            "maxLength": 100,
            "trim": true,
            "isPersonalData": true
        },
        "gender": {
            "type": "enum",
            "options": ["", "male", "female", "other"],
            "default": "",
            "style": {"male": "info", "female": "info", "other": "info"}
        },
        "phone": {
            "type": "phone",
            "required": true,
            "typeList": ["Mobile", "Home", "Work", "Other"],
            "defaultType": "Mobile",
            "isPersonalData": true
        },
        "emailAddress": {
            "type": "email",
            "isPersonalData": true
        },
        "dateOfBirth": {
            "type": "date",
            "isPersonalData": true
        },
        "age": {
            "type": "int",
            "notStorable": true,
            "readOnly": true,
            "view": "espo-dental:views/preliminary-patient/fields/age"
        },
        "status": {
            "type": "enum",
            "options": ["entered", "booked", "processed", "no_show"],
            "default": "entered",
            "audited": true,
            "style": {
                "entered": "default",
                "booked": "primary",
                "processed": "success",
                "no_show": "danger"
            }
        },
        "source": {
            "type": "enum",
            "options": ["", "walk_in", "phone", "online", "referral", "other"],
            "default": ""
        },
        "clinic": {
            "type": "link"
        },
        "convertedToPatient": {
            "type": "linkOne",
            "readOnly": true
        },
        "convertedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "questionnaireCompleted": {
            "type": "bool",
            "readOnly": true,
            "default": false,
            "tooltip": true
        },
        "lastQuestionnaireAt": {
            "type": "datetime",
            "readOnly": true
        },
        "description": {
            "type": "text"
        },
        "createdAt": {"type": "datetime", "readOnly": true},
        "modifiedAt": {"type": "datetime", "readOnly": true},
        "createdBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "modifiedBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "assignedUser": {"type": "link", "view": "views/fields/assigned-user"},
        "teams": {"type": "linkMultiple", "view": "views/fields/teams"}
    },
    "links": {
        "clinic": {"type": "belongsTo", "entity": "Clinic", "foreign": "preliminaryPatients"},
        "convertedToPatient": {"type": "hasOne", "entity": "Patient", "foreign": "convertedFromPreliminary"},
        "healthQuestionnaires": {"type": "hasMany", "entity": "HealthQuestionnaire", "foreign": "preliminaryPatient"},
        "questionnaireTokens": {"type": "hasMany", "entity": "QuestionnaireToken", "foreign": "preliminaryPatient"},
        "appointments": {"type": "hasChildren", "entity": "Appointment", "foreign": "parent"},
        "createdBy": {"type": "belongsTo", "entity": "User"},
        "modifiedBy": {"type": "belongsTo", "entity": "User"},
        "assignedUser": {"type": "belongsTo", "entity": "User"},
        "teams": {"type": "hasMany", "entity": "Team", "relationName": "entityTeam", "layoutRelationshipsDisabled": true}
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "createdAt": {"columns": ["createdAt", "deleted"]},
        "lastName": {"columns": ["lastName", "firstName"]},
        "status": {"columns": ["status", "deleted"]},
        "questionnaireCompleted": {"columns": ["questionnaireCompleted", "deleted"]},
        "clinic": {"columns": ["clinicId"]}
    }
}
