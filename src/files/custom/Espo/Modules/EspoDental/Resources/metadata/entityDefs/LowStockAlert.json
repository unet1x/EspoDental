{
    "fields": {
        "name": {"type": "varchar", "required": true, "maxLength": 255},
        "material": {"type": "link", "required": true},
        "clinic": {"type": "link"},
        "level": {
            "type": "enum",
            "options": ["low", "critical", "out"],
            "default": "low",
            "required": true,
            "audited": true,
            "style": {"low": "warning", "critical": "danger", "out": "danger"}
        },
        "currentStock": {"type": "float", "readOnly": true},
        "threshold": {"type": "float", "readOnly": true},
        "status": {
            "type": "enum",
            "options": ["open", "acknowledged", "resolved"],
            "default": "open",
            "audited": true,
            "style": {"open": "warning", "acknowledged": "info", "resolved": "success"}
        },
        "raisedAt": {"type": "datetime", "required": true, "readOnly": true},
        "resolvedAt": {"type": "datetime", "readOnly": true},
        "acknowledgedBy": {"type": "link", "view": "views/fields/user"},
        "notes": {"type": "text"},
        "createdAt": {"type": "datetime", "readOnly": true},
        "modifiedAt": {"type": "datetime", "readOnly": true},
        "createdBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "modifiedBy": {"type": "link", "readOnly": true, "view": "views/fields/user"},
        "assignedUser": {"type": "link", "view": "views/fields/assigned-user"},
        "teams": {"type": "linkMultiple", "view": "views/fields/teams"}
    },
    "links": {
        "material": {"type": "belongsTo", "entity": "Material", "foreign": "alerts"},
        "clinic": {"type": "belongsTo", "entity": "Clinic"},
        "acknowledgedBy": {"type": "belongsTo", "entity": "User"},
        "createdBy": {"type": "belongsTo", "entity": "User"},
        "modifiedBy": {"type": "belongsTo", "entity": "User"},
        "assignedUser": {"type": "belongsTo", "entity": "User"},
        "teams": {"type": "hasMany", "entity": "Team", "relationName": "entityTeam", "layoutRelationshipsDisabled": true}
    },
    "collection": {"orderBy": "raisedAt", "order": "desc"},
    "indexes": {
        "material_status": {"columns": ["materialId", "status"]},
        "raised": {"columns": ["raisedAt"]}
    }
}
