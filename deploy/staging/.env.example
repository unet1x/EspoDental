# EspoDental STAGING environment.
# Copy to .env next to deploy/staging/docker-compose.yml.
# Never commit this file with real values.
#
# IMPORTANT: staging holds REAL patient data nightly-restored from prod.
# Restrict access to a single admin (network, DSM Reverse Proxy with HTTP
# basic auth, VPN-only, or 2FA at the EspoCRM level).

# ---------- Timezone ----------
TZ=Europe/Moscow

# ---------- MariaDB (own credentials, own root password) ----------
MARIADB_ROOT_PASSWORD=change-me-strong-staging-root
ESPOCRM_DATABASE_NAME=espodental_staging
ESPOCRM_DATABASE_USER=espodental_staging
ESPOCRM_DATABASE_PASSWORD=change-me-strong-staging-db

# ---------- EspoCRM admin (created on first install only; will be
# overwritten by the nightly restore from prod) ----------
ESPOCRM_ADMIN_USERNAME=admin
ESPOCRM_ADMIN_PASSWORD=change-me-strong-admin

# Public URL of the staging instance. Behind DSM Reverse Proxy with HTTPS
# pick a distinct subdomain so users (and you!) can never confuse it with
# prod, e.g. staging-dental.example.com.
ESPOCRM_SITE_URL=http://localhost:8090
ESPOCRM_WEBSOCKET_URL=ws://localhost:8091

# ---------- Host ports (different from prod which uses 8080/8081) ----------
ESPOCRM_HTTP_PORT=8090
ESPOCRM_WS_PORT=8091

# ---------- Module source path on the NAS ----------
# Must point to a SEPARATE git clone from prod's MODULE_HOST_PATH, so that
# `git checkout` on staging does not move prod simultaneously.
MODULE_HOST_PATH=/volume1/espomodule-staging

# ---------- PHP tuning (match prod) ----------
PHP_MAX_EXECUTION_TIME=180
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_MAX_FILE_SIZE=64M
PHP_POST_MAX_SIZE=64M
