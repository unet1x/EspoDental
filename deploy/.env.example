# EspoDental — environment configuration
# Copy to .env (next to docker-compose.yml) and fill in real values.
# Never commit .env to git.

# ---------- Timezone ----------
TZ=Europe/Moscow

# ---------- MariaDB ----------
MARIADB_ROOT_PASSWORD=change-me-strong-root
ESPOCRM_DATABASE_NAME=espodental
ESPOCRM_DATABASE_USER=espodental
ESPOCRM_DATABASE_PASSWORD=change-me-strong-user

# ---------- EspoCRM admin (created on first install only) ----------
ESPOCRM_ADMIN_USERNAME=admin
ESPOCRM_ADMIN_PASSWORD=change-me-strong-admin

# Public site URL (used by Espo for absolute links, OAuth, websocket, etc.)
# Behind DSM Reverse Proxy + HTTPS this should be https://dental.example.com
ESPOCRM_SITE_URL=http://localhost:8080

# WebSocket public URL (browser connects here through DSM reverse proxy)
# Behind HTTPS: wss://dental.example.com  (proxy /wss -> espocrm-websocket:8080)
ESPOCRM_WEBSOCKET_URL=ws://localhost:8081

# ---------- Host ports (mapped via Synology) ----------
# Recommended: keep them on 127.0.0.1 inside DSM and expose with reverse proxy.
ESPOCRM_HTTP_PORT=8080
ESPOCRM_WS_PORT=8081

# ---------- PHP tuning ----------
PHP_MAX_EXECUTION_TIME=180
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_MAX_FILE_SIZE=64M
PHP_POST_MAX_SIZE=64M

# ---------- Module: Telegram bot for appointment reminders ----------
# Created in BotFather. Read by the EspoDental module at runtime.
TELEGRAM_BOT_TOKEN=

# ---------- Backups ----------
BACKUP_DIR=/volume2/espodental/data/backups
BACKUP_RETENTION_DAYS=30
