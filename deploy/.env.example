# EspoDental — environment configuration
# Copy to .env (next to docker-compose.yml) and fill in real values.
# Never commit .env to git.

# ---------- Timezone ----------
TZ=Europe/Moscow

# ---------- MariaDB ----------
MARIADB_ROOT_PASSWORD=change-me-strong-root
ESPOCRM_DATABASE_NAME=espodental
ESPOCRM_DATABASE_USER=espodental
ESPOCRM_DATABASE_PASSWORD=change-me-strong-user

# ---------- EspoCRM admin (created on first install only) ----------
ESPOCRM_ADMIN_USERNAME=admin
ESPOCRM_ADMIN_PASSWORD=change-me-strong-admin

# Public site URL (used by Espo for absolute links, OAuth, websocket, etc.)
# Behind DSM Reverse Proxy + HTTPS this should be https://dental.example.com
ESPOCRM_SITE_URL=http://localhost:8080

# WebSocket public URL (browser connects here through DSM reverse proxy)
# Behind HTTPS: wss://dental.example.com  (proxy /wss -> espocrm-websocket:8080)
ESPOCRM_WEBSOCKET_URL=ws://localhost:8081

# ---------- Host ports (mapped via Synology) ----------
# Recommended: keep them on 127.0.0.1 inside DSM and expose with reverse proxy.
ESPOCRM_HTTP_PORT=8080
ESPOCRM_WS_PORT=8081

# ---------- PHP tuning ----------
PHP_MAX_EXECUTION_TIME=180
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_MAX_FILE_SIZE=64M
PHP_POST_MAX_SIZE=64M

# ---------- Module: Telegram bot for appointment reminders ----------
# Created in BotFather. Read by the EspoDental module at runtime.
TELEGRAM_BOT_TOKEN=

# ---------- Backups ----------
# Used by deploy/scripts/backup-prod.sh and restore-to-staging.sh.
BACKUP_DIR=/volume2/espodental/backups
BACKUP_RETENTION_DAYS=14
INCLUDE_UPLOADS=1
# Where prod stores its data volume (data/upload lives below it).
PROD_UPLOAD_PATH=/volume2/espodental/data

# ---------- Nightly pipeline alerts ----------
# Sent on backup failure, restore failure or staging sanity-check failure.
# Configure either channel (or both); empty values skip that channel.
#
# Telegram: dedicated chat with a bot. Bot can be the same one you use for
# appointment reminders — only the chat_id needs to point at you.
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# Email via curl-SMTP. ALERT_SMTP_URL is the upstream relay, e.g.
#   smtps://smtp.example.com:465   (TLS-only port)
#   smtp://smtp.example.com:587    (STARTTLS upgrade)
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
ALERT_SMTP_URL=
ALERT_SMTP_USER=
ALERT_SMTP_PASS=

# ---------- Staging instance (read by nightly.sh / restore-to-staging.sh) ----------
STAGING_COMPOSE_DIR=/volume1/docker/espodental-staging
STAGING_DATA_PATH=/volume2/espodental-staging/data
STAGING_HEALTH_URL=http://localhost:8090/
STAGING_HEALTH_TIMEOUT_SEC=180
# Table whose row count is compared between prod and staging after restore.
PATIENT_TABLE_NAME=patient
# Log directory for the orchestrator.
LOG_DIR=/volume2/espodental/logs
