{
    "name": "espodental/espodental",
    "description": "Dental clinic information system built as an EspoCRM module.",
    "type": "espocrm-extension",
    "license": "MIT",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "Espo\\Modules\\EspoDental\\": "src/files/custom/Espo/Modules/EspoDental/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EspoDental\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
